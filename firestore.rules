rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isSignedIn() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'alaa12mohmad@gmail.com';
    }
    function isAppAdmin() {
      return isSuperAdmin() ||
        (isSignedIn() &&
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true);
    }
    function wsMemberIds(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)).data.memberUids;
    }
    function isWsMember(wsId) {
      return isSignedIn() && request.auth.uid in wsMemberIds(wsId);
    }
    function wsMemberRole(wsId, uid) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)/members/$(uid)).data.role;
    }
    function isWsManager(wsId) {
      return isSignedIn() &&
        (wsMemberRole(wsId, request.auth.uid) == 'owner' ||
         wsMemberRole(wsId, request.auth.uid) == 'manager');
    }

    // ═══ البيانات الشخصية ═══
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId;
    }
    // المدير يقدر يشوف (قراءة فقط) مهام أي موظف الشخصية للمتابعة — التعديل يفضل حصري لصاحب الحساب
    match /users/{userId}/tasks/{taskId} {
      allow read: if isAppAdmin();
    }
    match /users/{userId}/notifications/{notifId} {
      allow read, update, delete: if request.auth.uid == userId;
      allow create: if isSignedIn();
    }

    // ═══ ملفات الحضور ═══
    match /userProfiles/{uid} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == uid || isAppAdmin();
    }
    match /userProfiles/{uid}/sessions/{sId} {
      allow read: if request.auth.uid == uid || isSuperAdmin();
      allow create: if request.auth.uid == uid;
    }

    // ═══ المساحات المشتركة ═══
    match /workspaces/{wsId} {
      allow read: if isWsMember(wsId);
      allow create: if isSignedIn();
      allow update: if isWsManager(wsId)
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
            && request.auth.uid in request.resource.data.memberUids
            && !(request.auth.uid in resource.data.memberUids));
    }
    match /workspaces/{wsId}/members/{memberId} {
      allow read: if isWsMember(wsId);
      allow create: if request.auth.uid == memberId && request.resource.data.role == 'member';
      allow update, delete: if isWsManager(wsId) || isSuperAdmin();
    }
    match /workspaces/{wsId}/tasks/{taskId} {
      // المدير/المالك يشوف كل المهام؛ العضو العادي يشوف بس اللي مُسندة له أو أنشأها هو
      allow read: if isWsManager(wsId)
        || resource.data.assignedToUid == request.auth.uid
        || resource.data.createdByUid == request.auth.uid;
      allow create, delete: if isWsManager(wsId);
      allow update: if isWsManager(wsId)
        || (request.auth.uid == resource.data.assignedToUid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'steps']));
    }
    match /workspaces/{wsId}/tasks/{taskId}/comments/{cId} {
      allow read, create: if isWsMember(wsId);
    }

    // ═══ الدعوات ═══
    match /invitations/{invId} {
      allow read: if resource.data.inviteeEmail == request.auth.token.email
                  || resource.data.invitedByUid == request.auth.uid;
      allow create: if isSignedIn() && isWsManager(request.resource.data.workspaceId);
      allow update: if resource.data.inviteeEmail == request.auth.token.email;
    }

    // ═══ المهام المُسندة (نظام المدير العام) ═══
    match /assignedTasks/{taskId} {
      allow read: if isAppAdmin()
                  || request.auth.uid == resource.data.assignedToUid
                  || request.auth.uid == resource.data.assignedByUid;
      allow create: if isAppAdmin();
      allow update: if isAppAdmin()
        || (request.auth.uid == resource.data.assignedToUid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'steps']));
      allow delete: if isAppAdmin();
    }
    match /assignedTasks/{taskId}/comments/{cId} {
      allow read, create: if isAppAdmin()
        || request.auth.uid == get(/databases/$(database)/documents/assignedTasks/$(taskId)).data.assignedToUid
        || request.auth.uid == get(/databases/$(database)/documents/assignedTasks/$(taskId)).data.assignedByUid;
    }

    // ═══ المحادثات ═══
    match /chats/{roomId}/messages/{msgId} {
      allow read, create: if isSignedIn() &&
        (roomId == 'general' || request.auth.uid in roomId.split('_'));
    }

    // ═══ المديرون ═══
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ═══ أكواد تسجيل الموظفين ═══
    match /regCodes/{code} {
      // القراءة مسموحة لأي مستخدم مسجّل دخول (لازم يقرأ الكود بعد إنشاء حسابه للتحقق منه)
      allow read: if isSignedIn();
      allow create: if isAppAdmin();
      // الاستخدام: انتقال واحد فقط من used=false إلى used=true، والمستخدم يحدد نفسه فقط
      allow update: if isSignedIn()
        && resource.data.used == false
        && request.resource.data.used == true
        && request.resource.data.usedByUid == request.auth.uid;
      allow delete: if isAppAdmin();
    }

    // ═══ سجل إنجاز المهام (دائم وغير قابل للتعديل) ═══
    match /taskHistory/{entryId} {
      allow read: if isAppAdmin() || resource.data.employeeUid == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
